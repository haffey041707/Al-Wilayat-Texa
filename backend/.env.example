# Copy to backend/.env and fill in. This file (.env.example) is safe to commit;
# .env is git-ignored. NEVER commit a real key.

# Wilayat Chat live provider — set ONE of these.
# OpenAI is preferred when present.
OPENAI_API_KEY=sk-...
# WILAYAT_OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (used only if OPENAI_API_KEY is not set)
# ANTHROPIC_API_KEY=sk-ant-...
# WILAYAT_AI_MODEL=claude-opus-4-8

# ---- Authentication ----
# Secret used to sign JWT access tokens. Use a long random value in production:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WILAYAT_SECRET=change-me-to-a-long-random-string
# Where the web frontend is served (used to build password-reset links).
FRONTEND_BASE=http://localhost:5500

# ---- E-mail (password reset codes + admin alerts) ----
# Reset CODES and admin alerts are sent from the owner's address below.
# To send REAL e-mail via the owner's Gmail (haffeypythonista@gmail.com):
#   1. Enable 2-Step Verification on that Google account.
#   2. Create an "App password" (Google Account → Security → App passwords).
#   3. Put it in SMTP_PASS and uncomment the SMTP_HOST line.
# Leave SMTP_HOST empty during local dev — the 6-digit code is then printed to
# the backend log so you can test the flow without a mail server.
SMTP_HOST=               # smtp.gmail.com  (uncomment to enable real sending)
SMTP_PORT=587
SMTP_USER=haffeypythonista@gmail.com
SMTP_PASS=               # 16-char Gmail app password
SMTP_FROM=haffeypythonista@gmail.com
SMTP_TLS=1
# Failed-login security alerts are sent here.
ADMIN_ALERT_EMAIL=haffeypythonista@gmail.com
